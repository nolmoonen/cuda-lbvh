import subprocess
import os

exe_loc = '$<TARGET_FILE:cuda-lbvh>'
obj_dir = '@CMAKE_SOURCE_DIR@/scenes'

if __name__ == '__main__':
    size = 1024
    samples = 128
    subprocess.run([
        exe_loc,
        os.path.join(obj_dir, 'sanmiguel.obj'),
        'sanmiguel.png',
        str(size),
        str(size),
        str(samples),
        '8.0', '1.5', '10.5',  # origin
        '9.0', '1.5',  '9.5',  # target
        '0.0', '1.0',  '0.0']) # up
    subprocess.run([
        exe_loc,
        os.path.join(obj_dir, 'sibenik.obj'),
        'sibenik.png',
        str(size),
        str(size),
        str(samples),
        '-15.5', '-2.5', '0.0',  # origin
        '-14.5', '-2.5', '0.0',  # target
          '0.0',  '1.0', '0.0']) # up
    subprocess.run([
        exe_loc,
        os.path.join(obj_dir, 'sponza.obj'),
        'sponza.png',
        str(size),
        str(size),
        str(samples),
        '800.0', '580.0', '-35.0',  # origin
        '799.0', '580.0', '-35.0',  # target
          '0.0',   '1.0',   '0.0']) # up
